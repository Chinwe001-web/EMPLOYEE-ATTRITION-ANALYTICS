--handling null columns
--replace null columns in job satisfaction column with mode 
- Step 1: Find the mode (most common satisfaction score)
SELECT job_satisfaction, COUNT(*) AS frequency
FROM employee_attrition
WHERE job_satisfaction IS NOT NULL
GROUP BY job_satisfaction
ORDER BY frequency DESC
LIMIT 1;

-- Step 2: Replace nulls with the mode
UPDATE employee_attrition
SET job_satisfaction = (
    SELECT job_satisfaction
    FROM employee_attrition
	WHERE job_satisfaction IS NOT NULL
    GROUP BY job_satisfaction
    ORDER BY COUNT(*) DESC
    LIMIT 1
)
WHERE job_satisfaction IS NULL;

-- Step 3: Verify no nulls remain
SELECT COUNT(*) AS remaining_nulls
FROM employee_attrition
WHERE job_satisfaction IS NULL;

--replace nulls in environment satisfaction with mode by department
- Step 1: Find the mode per department
SELECT department, environment_satisfaction, COUNT(*) AS freq
FROM employee_attrition
WHERE environment_satisfaction IS NOT NULL
GROUP BY department, environment_satisfaction
ORDER BY department, freq DESC;

-- Step 2: Replace nulls with the mode within the same department
UPDATE employee_attrition a
SET environment_satisfaction = (
    SELECT environment_satisfaction
    FROM employee_attrition b
    WHERE b.department = a.department
    AND b.environment_satisfaction IS NOT NULL
    GROUP BY environment_satisfaction
    ORDER BY COUNT(*) DESC
    LIMIT 1
)
WHERE environment_satisfaction IS NULL;

-- Step 3: Verify
SELECT COUNT(*) AS remaining_nulls
FROM employee_attrition
WHERE environment_satisfaction IS NULL;

--replace nulls in training times last year with median by jobrole

-- Step 1: Find the median training times per jobrole
SELECT 
    job_role,
    PERCENTILE_CONT(0.5) WITHIN GROUP 
    (ORDER BY training_times_last_year) AS median_training
FROM employee_attrition
WHERE training_times_last_year IS NOT NULL
GROUP BY job_role;

-- Step 2: Replace nulls with the median for the same job role
UPDATE employee_attrition a
SET training_times_last_year = (
    SELECT ROUND(
        PERCENTILE_CONT(0.5) WITHIN GROUP 
        (ORDER BY training_times_last_year)
    )
    FROM employee_attrition b
    WHERE b.job_role = a.job_role
    AND b.training_times_last_year IS NOT NULL
)
WHERE training_times_last_year IS NULL;

-- Step 3: Verify
SELECT COUNT(*) AS remaining_nulls
FROM employee_attrition
WHERE training_times_last_year IS NULL;

--replace nulls in distance from home by average of department
- Step 1: Find the average distance per department
SELECT 
    department,
    ROUND(AVG(distance_from_home), 0) AS avg_distance
FROM employee_attrition
WHERE distance_from_home IS NOT NULL
GROUP BY department;

-- Step 2: Replace nulls with the average for the same department
UPDATE employee_attrition a
SET distance_from_home = (
    SELECT ROUND(AVG(distance_from_home), 0)
    FROM employee_attrition b
	WHERE b.department = a.department
    AND b.distance_from_home IS NOT NULL
)
WHERE distance_from_home IS NULL;

-- Step 3: Verify
SELECT COUNT(*) AS remaining_nulls
FROM employee_attrition
WHERE distance_from_home IS NULL;

--Verify for nulls with columns that had one
SELECT
    COUNT(*) AS total_rows,
    COUNT(*) - COUNT(job_satisfaction) AS null_job_sat,
    COUNT(*) - COUNT(environment_satisfaction) AS null_env_sat,
    COUNT(*) - COUNT(training_times_last_year) AS null_training,
    COUNT(*) - COUNT(distance_from_home) AS null_distance
FROM employee_attrition;

